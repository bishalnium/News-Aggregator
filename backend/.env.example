APP_NAME=News Codex Aggregator
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173

DATABASE_URL=mysql://newscodex:newscodex@localhost:3306/newscodex

# Cerebras — comma-separated keys for rotation (supports CEREBRAS_API_KEY for backward compat)
CEREBRAS_API_KEYS=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
CEREBRAS_CHAT_MODEL=zai-glm-4.7
CEREBRAS_RPM=5
CEREBRAS_RPH=150
CEREBRAS_RPD=2400
CEREBRAS_KEY_COOLDOWN_SECONDS=90

# Groq — comma-separated keys for rotation
GROQ_API_KEYS=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_RPM=30
GROQ_RPD=1000
GROQ_KEY_COOLDOWN_SECONDS=120

# Gemini AI Studio keys — last resort only (comma-separated)
GEMINI_API_KEYS=
GEMINI_PRIMARY_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_PRIMARY_RPM=30
GEMINI_FALLBACK_RPM=15
GEMINI_REQUESTS_PER_DAY=1500
GEMINI_KEY_COOLDOWN_SECONDS=90

# Provider priority: GPT-OSS first, Gemini ALWAYS last
LLM_PROVIDER_ORDER=groq,cerebras,gemini
SUMMARY_PROVIDER_ORDER=groq,cerebras,gemini
CLASSIFICATION_PROVIDER_ORDER=groq,cerebras,gemini
CHAT_DEFAULT_MODEL=groq_gpt_oss
CHAT_GROQ_MODEL=openai/gpt-oss-120b

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+910000000000
TELEGRAM_CHANNELS=your_channel_username,second_channel_username
TELEGRAM_FAST_CLASSIFICATION=true
FAST_SUMMARY_MODE=false
